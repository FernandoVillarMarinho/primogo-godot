; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Primogo"
config/description="Puzzle educacional de números primos. Reconstrução Godot 4 a partir das specs Reversa."
run/main_scene="res://features/main_menu/splash.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://assets/images/icon/icone-512px.png"

[autoload]

ProgressionStore="*res://autoload/progression_store.gd"
AudioBus="*res://autoload/audio_bus.gd"
SceneRouter="*res://autoload/scene_router.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/mode=3
window/size/window_width_override=486
window/size/window_height_override=864
window/size/initial_position_type=1
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=1

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
